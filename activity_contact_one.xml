<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/txtContactOneName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Andrea Long"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/txtContactOneAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Address: 123 Apple Street, Norfolk, VA 23501"
        android:textSize="18sp"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/txtContactOnePhone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phone: (757) 555-1234"
        android:textSize="18sp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/txtContactOneEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Email: andrea.long@email.com"
        android:textSize="18sp"
        android:layout_marginTop="8dp" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/img_pixofgirl" />

</LinearLayout>